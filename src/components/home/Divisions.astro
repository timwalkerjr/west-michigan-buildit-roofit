---
// Divisions - high-contrast split composition
import Container from '@/components/Container.astro';
---

<section id="divisions" class="py-24 bg-background" data-ps="src/components/home/Divisions.astro:xwg7o7">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-16" data-ps="src/components/home/Divisions.astro:a0tels">
      <h2 class="text-h2 font-extrabold mb-4 text-foreground reveal" data-ps="src/components/home/Divisions.astro:zbs9s4">Dual Division Expertise</h2>
      <p class="text-lg text-muted-foreground reveal reveal-delay-1" data-ps="src/components/home/Divisions.astro:iwsekw">
        We've structured our company into two specialized divisions to ensure expert focus on every aspect of your home's exterior and structural integrity.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8" data-ps="src/components/home/Divisions.astro:a0telt">
      <!-- BUILDIT Division -->
      <div class="group relative overflow-hidden bg-surface rounded-[2rem] shadow-sm hover:shadow-xl transition-all duration-300 reveal-left border border-border" data-ps="src/components/home/Divisions.astro:kaqxs9">
        <div class="aspect-[16/9] overflow-hidden" data-ps="src/components/home/Divisions.astro:kaqxs8">
          <img 
            src="https://images.pexels.com/photos/33405084/pexels-photo-33405084.jpeg?auto=compress&cs=tinysrgb&w=800" 
            alt="Custom home construction" 
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy" data-ps="src/components/home/Divisions.astro:7ikaa9" />
        </div>
        <div class="relative p-8 md:p-12" data-ps="src/components/home/Divisions.astro:kaqxs6">
          <div class="flex items-center gap-3 mb-6" data-ps="src/components/home/Divisions.astro:kaqxs5">
            <span class="w-8 h-1 bg-primary rounded-full" data-ps="src/components/home/Divisions.astro:hoefed"></span>
            <h3 class="text-2xl md:text-3xl font-extrabold text-foreground" data-ps="src/components/home/Divisions.astro:kndcki">BUILDIT Division</h3>
          </div>
          <p class="text-muted-foreground mb-8 text-lg" data-ps="src/components/home/Divisions.astro:iwseli">
            Custom lakefront homes, structural additions, and comprehensive exterior remodeling built to withstand coastal West Michigan environments.
          </p>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-y-3 gap-x-6 mb-10 text-foreground font-semibold">
            <li class="flex items-center gap-3" data-ps="src/components/home/Divisions.astro:yycvqs">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center text-primary" data-ps="src/components/home/Divisions.astro:hoefdr">✓</span> New Construction
            </li>
            <li class="flex items-center gap-3" data-ps="src/components/home/Divisions.astro:yycvq6">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center text-primary" data-ps="src/components/home/Divisions.astro:hoefdq">✓</span> Remodeling
            </li>
            <li class="flex items-center gap-3" data-ps="src/components/home/Divisions.astro:yycvq5">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center text-primary" data-ps="src/components/home/Divisions.astro:hoefdp">✓</span> Framing & Site Work
            </li>
            <li class="flex items-center gap-3" data-ps="src/components/home/Divisions.astro:yycvq4">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center text-primary" data-ps="src/components/home/Divisions.astro:hoefdo">✓</span> Custom Projects
            </li>
          </ul>
          <a href="/services" class="inline-block bg-secondary text-secondary-foreground px-8 py-4 rounded-xl font-bold transition-all hover:bg-secondary-hover" data-ps="src/components/home/Divisions.astro:q0qb9t">
            BUILDIT Services
          </a>
        </div>
      </div>

      <!-- ROOFIT Division -->
      <div class="group relative overflow-hidden bg-primary rounded-[2rem] shadow-sm hover:shadow-xl transition-all duration-300 reveal-right text-white" data-ps="src/components/home/Divisions.astro:kaqxs4">
         <div class="aspect-[16/9] overflow-hidden" data-ps="src/components/home/Divisions.astro:kaqxs3">
          <img 
            src="https://images.pexels.com/photos/37623627/pexels-photo-37623627.jpeg?auto=compress&cs=tinysrgb&w=800" 
            alt="Roofing installation" 
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy" data-ps="src/components/home/Divisions.astro:7ikaaa" />
          <div class="absolute inset-0 bg-primary/40 group-hover:bg-primary/20 transition-colors" data-ps="src/components/home/Divisions.astro:kaqxs2"></div>
        </div>
        <div class="relative p-8 md:p-12" data-ps="src/components/home/Divisions.astro:kaqxs1">
          <div class="flex items-center gap-3 mb-6" data-ps="src/components/home/Divisions.astro:kaqxs0">
            <span class="w-8 h-1 bg-white rounded-full" data-ps="src/components/home/Divisions.astro:hoefdn"></span>
            <h3 class="text-2xl md:text-3xl font-extrabold" data-ps="src/components/home/Divisions.astro:kndckj">ROOFIT Division</h3>
          </div>
          <p class="text-white/90 mb-8 text-lg" data-ps="src/components/home/Divisions.astro:iwselj">
            Asphalt shingle replacement, lifetime metal roofing, seamless gutters, and premium vinyl siding upgrades for maximum durability.
          </p>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-y-3 gap-x-6 mb-10 font-semibold">
            <li class="flex items-center gap-3" data-ps="src/components/home/Divisions.astro:yycvq3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-white/20 flex items-center justify-center text-white" data-ps="src/components/home/Divisions.astro:hoefdm">✓</span> Asphalt Shingles
            </li>
            <li class="flex items-center gap-3" data-ps="src/components/home/Divisions.astro:yycvq2">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-white/20 flex items-center justify-center text-white" data-ps="src/components/home/Divisions.astro:hoefdl">✓</span> Metal Roofing
            </li>
            <li class="flex items-center gap-3" data-ps="src/components/home/Divisions.astro:yycvq1">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-white/20 flex items-center justify-center text-white" data-ps="src/components/home/Divisions.astro:hoefdk">✓</span> Vinyl Siding
            </li>
            <li class="flex items-center gap-3" data-ps="src/components/home/Divisions.astro:yycvq0">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-white/20 flex items-center justify-center text-white" data-ps="src/components/home/Divisions.astro:hoefdj">✓</span> Seamless Gutters
            </li>
          </ul>
          <a href="/services" class="inline-block bg-white text-primary px-8 py-4 rounded-xl font-bold transition-all hover:bg-white/90 shadow-sm" data-ps="src/components/home/Divisions.astro:q0qb9u">
            ROOFIT Services
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>
