---
// FAQ - structured accordion component
import Container from '@/components/Container.astro';
---

<section id="faq" class="py-24 bg-surface border-y border-border" data-ps="src/components/home/FAQ.astro:wpdra8">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-16" data-ps="src/components/home/FAQ.astro:ybu4zb">
      <span class="text-primary font-bold uppercase tracking-widest text-sm mb-4 block" data-ps="src/components/home/FAQ.astro:o4fbow">Information Center</span>
      <h2 class="text-h2 font-bold reveal" data-ps="src/components/home/FAQ.astro:dzhsdr">Frequently Asked Questions</h2>
    </div>

    <div class="max-w-4xl mx-auto reveal reveal-delay-1" data-ps="src/components/home/FAQ.astro:ybu4za">
      <div class="space-y-4" data-ps="src/components/home/FAQ.astro:ybu4z9">
        <!-- Q1 -->
        <details class="group bg-background border border-border overflow-hidden rounded-sm" open>
          <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
            <h3 class="text-lg font-bold" data-ps="src/components/home/FAQ.astro:7art2i">Do you provide commercial roofing services?</h3>
            <span class="text-primary transition-transform duration-300 group-open:rotate-180" data-ps="src/components/home/FAQ.astro:o4fbox">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </span>
          </summary>
          <div class="p-6 pt-0 text-muted-foreground leading-relaxed border-t border-border/50" data-ps="src/components/home/FAQ.astro:ybu4z8">
            Yes, we provide reliable flat roof installation, repair, and maintenance for businesses of all sizes throughout the Grand Haven area. Our commercial teams are certified for various industrial roofing systems.
          </div>
        </details>

        <!-- Q2 -->
        <details class="group bg-background border border-border overflow-hidden rounded-sm">
          <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
            <h3 class="text-lg font-bold" data-ps="src/components/home/FAQ.astro:7art2h">Do you offer a lifetime guarantee on your products?</h3>
            <span class="text-primary transition-transform duration-300 group-open:rotate-180" data-ps="src/components/home/FAQ.astro:o4fboy">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </span>
          </summary>
          <div class="p-6 pt-0 text-muted-foreground leading-relaxed border-t border-border/50" data-ps="src/components/home/FAQ.astro:ybu4z7">
            We offer premium lifetime shingle and metal roofing systems. Most of our exterior upgrades come with robust manufacturer warranties backed by our own craftsmanship guarantee. Contact us for specific warranty details on your chosen materials.
          </div>
        </details>

        <!-- Q3 -->
        <details class="group bg-background border border-border overflow-hidden rounded-sm">
          <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
            <h3 class="text-lg font-bold" data-ps="src/components/home/FAQ.astro:7art2g">How long does a typical roof replacement take?</h3>
            <span class="text-primary transition-transform duration-300 group-open:rotate-180" data-ps="src/components/home/FAQ.astro:o4fboz">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </span>
          </summary>
          <div class="p-6 pt-0 text-muted-foreground leading-relaxed border-t border-border/50" data-ps="src/components/home/FAQ.astro:ybu4z6">
            Most residential roof replacements in West Michigan are completed within 1 to 3 days, depending on the size and complexity of the structure. We prioritize neat cleanup and minimal disruption to your daily routine.
          </div>
        </details>

        <!-- Q4 -->
        <details class="group bg-background border border-border overflow-hidden rounded-sm">
          <summary class="flex justify-between items-center p-6 cursor-pointer list-none">
            <h3 class="text-lg font-bold" data-ps="src/components/home/FAQ.astro:7art2f">Do you handle permits for home remodeling?</h3>
            <span class="text-primary transition-transform duration-300 group-open:rotate-180" data-ps="src/components/home/FAQ.astro:o4fbp0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </span>
          </summary>
          <div class="p-6 pt-0 text-muted-foreground leading-relaxed border-t border-border/50" data-ps="src/components/home/FAQ.astro:ybu4z5">
            Yes, the BUILDIT division manages all necessary building permits and structural inspections required by your local West Michigan municipality (Grand Haven, Spring Lake, Holland, etc.).
          </div>
        </details>
      </div>

      <div class="mt-12 text-center" data-ps="src/components/home/FAQ.astro:ybu4z4">
         <p class="text-muted-foreground mb-6" data-ps="src/components/home/FAQ.astro:v2sduj">Still have questions? Our support team is ready to help.</p>
         <a href="/faqs" class="text-primary font-bold uppercase tracking-widest hover:text-primary-hover transition-colors" data-ps="src/components/home/FAQ.astro:wudrfi">
            View All FAQs →
         </a>
      </div>
    </div>
  </Container>
</section>
