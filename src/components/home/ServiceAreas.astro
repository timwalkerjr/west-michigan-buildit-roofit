---
// Service Areas - regional proof section
import Container from '@/components/Container.astro';
---

<section id="service-areas" class="py-24 bg-slate-950 text-white overflow-hidden" data-ps="src/components/home/ServiceAreas.astro:7uvxvf">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center" data-ps="src/components/home/ServiceAreas.astro:5h31lu">
      <div class="reveal-left" data-ps="src/components/home/ServiceAreas.astro:5h31lt">
        <span class="text-primary font-bold uppercase tracking-widest text-sm mb-4 block" data-ps="src/components/home/ServiceAreas.astro:5y10pf">Regional Authority</span>
        <h2 class="text-h2 font-bold mb-6" data-ps="src/components/home/ServiceAreas.astro:44b67o">Your Local Lakeshore Contractors</h2>
        <p class="text-lg text-dark-muted-foreground mb-8" data-ps="src/components/home/ServiceAreas.astro:p34u9q">
          We are deeply rooted in West Michigan, serving Ottawa, Muskegon, and Allegan counties. Our crews understand the unique challenges of coastal climates and building codes along the shoreline.
        </p>

        <div class="grid grid-cols-2 gap-6 mb-10" data-ps="src/components/home/ServiceAreas.astro:5h31ls">
          <div class="border-l-2 border-primary pl-6 py-2" data-ps="src/components/home/ServiceAreas.astro:5h31lr">
            <h3 class="text-4xl font-bold mb-1" data-ps="src/components/home/ServiceAreas.astro:ak3qzz">Ottawa</h3>
            <p class="text-dark-muted-foreground text-sm uppercase tracking-wider" data-ps="src/components/home/ServiceAreas.astro:p34u9r">County Coverage</p>
          </div>
          <div class="border-l-2 border-primary pl-6 py-2" data-ps="src/components/home/ServiceAreas.astro:5h31l5">
            <h3 class="text-4xl font-bold mb-1" data-ps="src/components/home/ServiceAreas.astro:ak3qzy">Muskegon</h3>
            <p class="text-dark-muted-foreground text-sm uppercase tracking-wider" data-ps="src/components/home/ServiceAreas.astro:p34u9s">County Coverage</p>
          </div>
        </div>

        <div class="space-y-4" data-ps="src/components/home/ServiceAreas.astro:5h31l4">
          <div class="flex items-center gap-4" data-ps="src/components/home/ServiceAreas.astro:5h31l3">
            <div class="w-2 h-2 rounded-full bg-primary" data-ps="src/components/home/ServiceAreas.astro:5h31l2"></div>
            <span class="text-lg" data-ps="src/components/home/ServiceAreas.astro:5y10pg">Grand Haven & Spring Lake</span>
          </div>
          <div class="flex items-center gap-4" data-ps="src/components/home/ServiceAreas.astro:5h31l1">
            <div class="w-2 h-2 rounded-full bg-primary" data-ps="src/components/home/ServiceAreas.astro:5h31l0"></div>
            <span class="text-lg" data-ps="src/components/home/ServiceAreas.astro:5y10ph">Holland & Zeeland</span>
          </div>
          <div class="flex items-center gap-4" data-ps="src/components/home/ServiceAreas.astro:5h31kz">
            <div class="w-2 h-2 rounded-full bg-primary" data-ps="src/components/home/ServiceAreas.astro:5h31ky"></div>
            <span class="text-lg" data-ps="src/components/home/ServiceAreas.astro:5y10pi">Muskegon & North Muskegon</span>
          </div>
          <div class="flex items-center gap-4" data-ps="src/components/home/ServiceAreas.astro:5h31kx">
            <div class="w-2 h-2 rounded-full bg-primary" data-ps="src/components/home/ServiceAreas.astro:5h31kw"></div>
            <span class="text-lg" data-ps="src/components/home/ServiceAreas.astro:5y10pj">Fruitport & Norton Shores</span>
          </div>
        </div>

        <a href="/service-areas" class="mt-12 inline-flex items-center gap-3 text-primary font-bold uppercase tracking-widest hover:text-white transition-colors" data-ps="src/components/home/ServiceAreas.astro:w72qze">
          View Detailed Coverage Map
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <div class="relative reveal-right" data-ps="src/components/home/ServiceAreas.astro:6p3s08">
        <!-- Stylized Map Representation -->
        <div class="aspect-square bg-slate-900 border border-white/5 relative p-8" data-ps="src/components/home/ServiceAreas.astro:6p3s09">
          <div class="absolute inset-0 opacity-20 pointer-events-none" data-ps="src/components/home/ServiceAreas.astro:6p3s0a">
             <svg class="w-full h-full" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
               <path d="M20 20L40 30L60 10L80 40L90 80L50 90L10 60L20 20Z" stroke="white" stroke-width="0.5" />
               <circle cx="30" cy="40" r="1" fill="white" />
               <circle cx="50" cy="60" r="1" fill="white" />
               <circle cx="70" cy="30" r="1" fill="white" />
             </svg>
          </div>
          
          <div class="relative z-10 flex flex-col justify-center h-full text-center" data-ps="src/components/home/ServiceAreas.astro:6p3s0b">
             <div class="inline-block mx-auto mb-6 bg-primary/20 p-4 border border-primary/30" data-ps="src/components/home/ServiceAreas.astro:6p3s0c">
                <svg class="w-12 h-12 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
             </div>
             <h3 class="text-3xl font-bold mb-2" data-ps="src/components/home/ServiceAreas.astro:ak3qzx">Prompt Service</h3>
             <p class="text-dark-muted-foreground" data-ps="src/components/home/ServiceAreas.astro:p34uae">Locally based crews ready for dispatch across the West Michigan shoreline.</p>
             
             <div class="mt-8 flex justify-center gap-4" data-ps="src/components/home/ServiceAreas.astro:6p3s0d">
                <div class="px-4 py-2 bg-slate-800 border border-white/10 text-xs font-bold uppercase" data-ps="src/components/home/ServiceAreas.astro:6p3s0e">Dispatch 1: 231.533</div>
                <div class="px-4 py-2 bg-slate-800 border border-white/10 text-xs font-bold uppercase" data-ps="src/components/home/ServiceAreas.astro:6p3s0f">Dispatch 2: 616.885</div>
             </div>
          </div>
        </div>
        
        <!-- Decoration -->
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-primary/10 blur-3xl -z-10" data-ps="src/components/home/ServiceAreas.astro:6p3s0g"></div>
        <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-primary/10 blur-3xl -z-10" data-ps="src/components/home/ServiceAreas.astro:6p3s0h"></div>
      </div>
    </div>
  </Container>
</section>
