---
// Blog Preview - high-contrast cards for latest articles
import { getCollection } from 'astro:content';
import Container from '@/components/Container.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section id="blog-preview" class="py-24 bg-background" data-ps="src/components/home/BlogPreview.astro:ao1ecw">
  <Container>
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16" data-ps="src/components/home/BlogPreview.astro:ry2snt">
      <div class="max-w-2xl" data-ps="src/components/home/BlogPreview.astro:ry2snu">
        <span class="text-primary font-bold uppercase tracking-widest text-sm mb-4 block" data-ps="src/components/home/BlogPreview.astro:eopuoy">Homeowner Guides</span>
        <h2 class="text-h2 font-bold reveal" data-ps="src/components/home/BlogPreview.astro:ozcmfr">Latest Articles</h2>
      </div>
      <a href="/blog" class="text-primary font-bold border-b-2 border-primary pb-1 hover:text-primary-hover transition-colors reveal reveal-delay-1" data-ps="src/components/home/BlogPreview.astro:x1x0a0">
        Read All Articles
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-ps="src/components/home/BlogPreview.astro:ry2snv">
      {posts.map((post, i) => (
        <a href={`/blog/${post.id}`} class={`group bg-surface border border-border p-1 reveal reveal-delay-${i}`} data-ps={`src/components/home/BlogPreview.astro:x1x0a1-${i}`}>
          <div class="aspect-video overflow-hidden mb-6" data-ps={`src/components/home/BlogPreview.astro:ry2snw-${i}`}>
            {post.data.image ? (
              <img 
                src={post.data.image} 
                alt={post.data.title} 
                crossorigin="anonymous"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy" data-ps={`src/components/home/BlogPreview.astro:1x65zh-${i}`} />
            ) : (
              <div class="w-full h-full bg-slate-900 flex items-center justify-center text-primary/20" data-ps={`src/components/home/BlogPreview.astro:ry2snx-${i}`}>
                 <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l4 4v10a2 2 0 01-2 2zM14 2v4h4"/></svg>
              </div>
            )}
          </div>
          <div class="p-6 pt-0" data-ps={`src/components/home/BlogPreview.astro:ry2sny-${i}`}>
            <div class="flex items-center gap-3 mb-3" data-ps={`src/components/home/BlogPreview.astro:ry2snz-${i}`}>
              <span class="text-[10px] font-bold uppercase tracking-widest text-primary px-2 py-0.5 border border-primary/20" data-ps={`src/components/home/BlogPreview.astro:eopuoz-${i}`}>{post.data.category || 'Maintenance'}</span>
              <time class="text-xs text-muted-foreground">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
            </div>
            <h3 class="text-xl font-bold mb-3 group-hover:text-primary transition-colors" data-ps={`src/components/home/BlogPreview.astro:vdcibs-${i}`}>{post.data.title}</h3>
            <p class="text-muted-foreground mb-6 text-sm line-clamp-2" data-ps={`src/components/home/BlogPreview.astro:pxz3kc-${i}`}>
              {post.data.description}
            </p>
            <span class="text-primary text-sm font-bold uppercase tracking-wider flex items-center gap-2" data-ps={`src/components/home/BlogPreview.astro:eopup0-${i}`}>
              Read More
              <span class="transition-transform group-hover:translate-x-1" data-ps={`src/components/home/BlogPreview.astro:eopup1-${i}`}>→</span>
            </span>
          </div>
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-20 border border-dashed border-border" data-ps="src/components/home/BlogPreview.astro:ry2so0">
         <p class="text-muted-foreground" data-ps="src/components/home/BlogPreview.astro:pxz3kd">Stay tuned for helpful articles on West Michigan home care.</p>
      </div>
    )}
  </Container>
</section>
