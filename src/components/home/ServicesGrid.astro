---
// Services Grid - listing core offerings with literal URLs
import Container from '@/components/Container.astro';
---

<section id="services-grid" class="py-24 bg-secondary/30" data-ps="src/components/home/ServicesGrid.astro:f9s2p1">
  <Container>
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16" data-ps="src/components/home/ServicesGrid.astro:6m7ir8">
      <div class="max-w-2xl" data-ps="src/components/home/ServicesGrid.astro:6m7iru">
        <span class="text-primary font-semibold tracking-wide text-sm mb-4 block" data-ps="src/components/home/ServicesGrid.astro:n7egzd">Our Roofing and Construction Services</span>
        <h2 class="text-h2 font-extrabold reveal" data-ps="src/components/home/ServicesGrid.astro:5gnqf8">Expert Exterior Crafts</h2>
      </div>
      <a href="/services" class="text-primary font-bold hover:text-primary-hover transition-colors flex items-center gap-2 reveal reveal-delay-1" data-ps="src/components/home/ServicesGrid.astro:tqp34d">
        View all Services
        <span data-ps="src/components/home/ServicesGrid.astro:ujaanu">→</span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-ps="src/components/home/ServicesGrid.astro:6m7irv">
      <!-- Asphalt Roofing -->
      <div class="bg-surface rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden reveal group" data-ps="src/components/home/ServicesGrid.astro:6m7irw">
        <div class="aspect-video overflow-hidden" data-ps="src/components/home/ServicesGrid.astro:6m7irx">
          <img 
            src="https://images.pexels.com/photos/4334097/pexels-photo-4334097.jpeg?auto=compress&cs=tinysrgb&w=600" 
            alt="Asphalt Roofing" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy" data-ps="src/components/home/ServicesGrid.astro:43yefl" />
        </div>
        <div class="p-8" data-ps="src/components/home/ServicesGrid.astro:6m7iry">
          <h3 class="text-xl font-bold mb-3 text-foreground" data-ps="src/components/home/ServicesGrid.astro:97r6t3">Asphalt Roofing</h3>
          <p class="text-muted-foreground mb-6" data-ps="src/components/home/ServicesGrid.astro:y6h25w">
            Top-quality asphalt shingle installation, repair, and replacement, backed by expert craftsmanship and exceptional customer service.
          </p>
          <a href="/services" class="text-primary font-semibold flex items-center gap-2 group-hover:gap-3 transition-all" data-ps="src/components/home/ServicesGrid.astro:tqp34c">
            Read more
            <span data-ps="src/components/home/ServicesGrid.astro:n7egzc">→</span>
          </a>
        </div>
      </div>

      <!-- Metal Roofing -->
      <div class="bg-surface rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden reveal reveal-delay-1 group" data-ps="src/components/home/ServicesGrid.astro:6m7irz">
        <div class="aspect-video overflow-hidden" data-ps="src/components/home/ServicesGrid.astro:6m7is0">
          <img 
            src="https://images.pexels.com/photos/8312917/pexels-photo-8312917.jpeg?auto=compress&cs=tinysrgb&w=600" 
            alt="Metal Roofing" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy" data-ps="src/components/home/ServicesGrid.astro:43yefm" />
        </div>
        <div class="p-8" data-ps="src/components/home/ServicesGrid.astro:6m7is1">
          <h3 class="text-xl font-bold mb-3 text-foreground" data-ps="src/components/home/ServicesGrid.astro:97r6t2">Metal Roofing</h3>
          <p class="text-muted-foreground mb-6" data-ps="src/components/home/ServicesGrid.astro:y6h26i">
            Energy-efficient metal roofing installation and repair for homes and businesses, built by an experienced team to last for decades.
          </p>
          <a href="/services" class="text-primary font-semibold flex items-center gap-2 group-hover:gap-3 transition-all" data-ps="src/components/home/ServicesGrid.astro:tqp34b">
            Read more
            <span data-ps="src/components/home/ServicesGrid.astro:n7egzb">→</span>
          </a>
        </div>
      </div>

      <!-- Seamless Gutters -->
      <div class="bg-surface rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden reveal reveal-delay-2 group" data-ps="src/components/home/ServicesGrid.astro:6m7is2">
        <div class="aspect-video overflow-hidden" data-ps="src/components/home/ServicesGrid.astro:6m7is3">
          <img 
            src="https://images.pexels.com/photos/3258128/pexels-photo-3258128.jpeg?auto=compress&cs=tinysrgb&w=600" 
            alt="Seamless Gutters" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy" data-ps="src/components/home/ServicesGrid.astro:43yefn" />
        </div>
        <div class="p-8" data-ps="src/components/home/ServicesGrid.astro:mp6ve3">
          <h3 class="text-xl font-bold mb-3 text-foreground" data-ps="src/components/home/ServicesGrid.astro:97r6t1">Seamless Gutters</h3>
          <p class="text-muted-foreground mb-6" data-ps="src/components/home/ServicesGrid.astro:y6h26j">
            Custom seamless gutter installation for homes and businesses, available in a variety of materials and colors to protect your property.
          </p>
          <a href="/services" class="text-primary font-semibold flex items-center gap-2 group-hover:gap-3 transition-all" data-ps="src/components/home/ServicesGrid.astro:tqp34a">
            Read more
            <span data-ps="src/components/home/ServicesGrid.astro:n7egza">→</span>
          </a>
        </div>
      </div>

      <!-- Siding Installation -->
      <div class="bg-surface rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden reveal reveal-delay-3 group" data-ps="src/components/home/ServicesGrid.astro:mp6ve2">
        <div class="aspect-video overflow-hidden" data-ps="src/components/home/ServicesGrid.astro:mp6ve1">
          <img 
            src="https://images.pexels.com/photos/34382307/pexels-photo-34382307.jpeg?auto=compress&cs=tinysrgb&w=600" 
            alt="Siding Installation" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy" data-ps="src/components/home/ServicesGrid.astro:43yefo" />
        </div>
        <div class="p-8" data-ps="src/components/home/ServicesGrid.astro:mp6ve0">
          <h3 class="text-xl font-bold mb-3 text-foreground" data-ps="src/components/home/ServicesGrid.astro:97r6t0">Siding Installation</h3>
          <p class="text-muted-foreground mb-6" data-ps="src/components/home/ServicesGrid.astro:y6h26k">
            Expert vinyl siding installation for homes and businesses across Grand Haven and West Michigan, enhancing curb appeal.
          </p>
          <a href="/services" class="text-primary font-semibold flex items-center gap-2 group-hover:gap-3 transition-all" data-ps="src/components/home/ServicesGrid.astro:tqp349">
            Read more
            <span data-ps="src/components/home/ServicesGrid.astro:n7egz9">→</span>
          </a>
        </div>
      </div>

      <!-- Home Remodeling -->
      <div class="bg-surface rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden reveal reveal-delay-4 group" data-ps="src/components/home/ServicesGrid.astro:mp6vdz">
        <div class="aspect-video overflow-hidden" data-ps="src/components/home/ServicesGrid.astro:mp6vdy">
          <img 
            src="https://images.pexels.com/photos/33405084/pexels-photo-33405084.jpeg?auto=compress&cs=tinysrgb&w=600" 
            alt="Home Remodeling" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy" data-ps="src/components/home/ServicesGrid.astro:43yefp" />
        </div>
        <div class="p-8" data-ps="src/components/home/ServicesGrid.astro:mp6vdx">
          <h3 class="text-xl font-bold mb-3 text-foreground" data-ps="src/components/home/ServicesGrid.astro:97r6sz">Home Remodeling</h3>
          <p class="text-muted-foreground mb-6" data-ps="src/components/home/ServicesGrid.astro:y6h26l">
            Comprehensive home remodeling focused on exterior upgrades that enhance your property's appearance, durability, and value.
          </p>
          <a href="/services" class="text-primary font-semibold flex items-center gap-2 group-hover:gap-3 transition-all" data-ps="src/components/home/ServicesGrid.astro:tqp33n">
            Read more
            <span data-ps="src/components/home/ServicesGrid.astro:n7egz8">→</span>
          </a>
        </div>
      </div>

      <!-- Replacement Windows -->
      <div class="bg-surface rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden reveal reveal-delay-5 group" data-ps="src/components/home/ServicesGrid.astro:mp6vdw">
        <div class="aspect-video overflow-hidden" data-ps="src/components/home/ServicesGrid.astro:mp6vdv">
          <img 
            src="https://images.pexels.com/photos/4968509/pexels-photo-4968509.jpeg?auto=compress&cs=tinysrgb&w=600" 
            alt="Replacement Windows" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            loading="lazy" data-ps="src/components/home/ServicesGrid.astro:43yefq" />
        </div>
        <div class="p-8" data-ps="src/components/home/ServicesGrid.astro:mp6vdu">
          <h3 class="text-xl font-bold mb-3 text-foreground" data-ps="src/components/home/ServicesGrid.astro:97r6sd">Replacement Windows</h3>
          <p class="text-muted-foreground mb-6" data-ps="src/components/home/ServicesGrid.astro:y6h26m">
            Top-quality replacement windows for homes and businesses, pairing expert craftsmanship with exceptional service.
          </p>
          <a href="/services" class="text-primary font-semibold flex items-center gap-2 group-hover:gap-3 transition-all" data-ps="src/components/home/ServicesGrid.astro:tqp33m">
            Read more
            <span data-ps="src/components/home/ServicesGrid.astro:n7egz7">→</span>
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>
