---
// Navigation - structural dark header matching brand slate
import Container from '@/components/Container.astro';
import { SITE } from '@/config/site';

export interface Props {
  logo?: string;
}

const { logo = SITE.logo } = Astro.props;
---

<header id="navbar" class="sticky top-0 z-40 bg-surface/90 backdrop-blur-md border-b border-border transition-colors" data-ps="src/components/Navigation.astro:dt8k87">
  <nav class="py-4" data-ps="src/components/Navigation.astro:m59h3b">
    <Container class="flex justify-between items-center">
      <a href="/" class="flex items-center gap-2 no-underline" data-ps="src/components/Navigation.astro:kd8n5y">
        <img src={logo} alt={SITE.name} class="h-10 w-auto md:h-12" data-ps="src/components/Navigation.astro:logo-img" />
      </a>

      <div class="flex items-center gap-6" data-ps="src/components/Navigation.astro:gqvsdc">
        <div class="hidden lg:flex gap-8 items-center font-display" data-ps="src/components/Navigation.astro:gqvsdd">
          <a href="/about" class="text-foreground text-sm font-bold tracking-wide hover:text-primary transition-colors" data-ps="src/components/Navigation.astro:nav-abt">About</a>
          <a href="/services" class="text-foreground text-sm font-bold tracking-wide hover:text-primary transition-colors" data-ps="src/components/Navigation.astro:nav-serv">Services</a>
          <a href="/service-areas" class="text-foreground text-sm font-bold tracking-wide hover:text-primary transition-colors" data-ps="src/components/Navigation.astro:nav-area">Service Areas</a>
          <a href="/reviews" class="text-foreground text-sm font-bold tracking-wide hover:text-primary transition-colors" data-ps="src/components/Navigation.astro:nav-rev">Reviews</a>
          <a href="/faqs" class="text-foreground text-sm font-bold tracking-wide hover:text-primary transition-colors" data-ps="src/components/Navigation.astro:nav-faq">FAQs</a>
          <a href="/blog" class="text-foreground text-sm font-bold tracking-wide hover:text-primary transition-colors" data-ps="src/components/Navigation.astro:nav-blog">Articles</a>
        </div>

        <div class="hidden md:flex gap-4" data-ps="src/components/Navigation.astro:gqvsde">
           <a href="/contact" class="bg-primary hover:bg-primary-hover text-white px-6 py-2.5 rounded-xl text-sm font-bold transition-all shadow-sm hover:shadow-md" data-ps="src/components/Navigation.astro:nav-cta">
            Get an Estimate
          </a>
        </div>

        <button
          id="mobile-menu-button"
          type="button"
          class="lg:hidden p-2 text-foreground hover:text-primary transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
         data-ps="src/components/Navigation.astro:5ds1">
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </Container>
  </nav>

  <div
    id="mobile-menu"
    class="hidden lg:hidden overflow-hidden bg-surface border-t border-border"
    role="navigation"
    aria-label="Mobile navigation"
   data-ps="src/components/Navigation.astro:gqvsde">
    <nav class="flex flex-col py-6 px-6 gap-4 font-display" data-ps="src/components/Navigation.astro:m59h3a">
      <a href="/about" class="text-foreground text-lg font-bold tracking-wide" data-ps="src/components/Navigation.astro:mob-abt">About</a>
      <a href="/services" class="text-foreground text-lg font-bold tracking-wide" data-ps="src/components/Navigation.astro:mob-serv">Services</a>
      <a href="/service-areas" class="text-foreground text-lg font-bold tracking-wide" data-ps="src/components/Navigation.astro:mob-area">Service Areas</a>
      <a href="/reviews" class="text-foreground text-lg font-bold tracking-wide" data-ps="src/components/Navigation.astro:mob-rev">Reviews</a>
      <a href="/faqs" class="text-foreground text-lg font-bold tracking-wide" data-ps="src/components/Navigation.astro:mob-faq">FAQs</a>
      <a href="/blog" class="text-foreground text-lg font-bold tracking-wide" data-ps="src/components/Navigation.astro:mob-blog">Articles</a>
      <a href="/contact" class="bg-primary text-white text-center py-4 rounded-xl font-bold mt-4" data-ps="src/components/Navigation.astro:mob-cta">Get an Estimate</a>
    </nav>
  </div>
</header>

<script is:inline>
  const navbar = document.getElementById('navbar');
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIconOpen = document.getElementById('menu-icon-open');
  const menuIconClose = document.getElementById('menu-icon-close');

  function updateNavbar() {
    if (window.scrollY > 50) {
      navbar?.classList.add('bg-surface/98', 'shadow-sm');
      navbar?.classList.remove('bg-surface/90');
    } else {
      navbar?.classList.add('bg-surface/90');
      navbar?.classList.remove('bg-surface/98', 'shadow-sm');
    }
  }
  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  function toggleMenu() {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      menuIconOpen?.classList.remove('hidden');
      menuIconClose?.classList.add('hidden');
      mobileMenuButton?.setAttribute('aria-expanded', 'false');
    } else {
      mobileMenu?.classList.remove('hidden');
      menuIconOpen?.classList.add('hidden');
      menuIconClose?.classList.remove('hidden');
      mobileMenuButton?.setAttribute('aria-expanded', 'true');
    }
  }

  mobileMenuButton?.addEventListener('click', toggleMenu);
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      menuIconOpen?.classList.remove('hidden');
      menuIconClose?.classList.add('hidden');
      mobileMenuButton?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
